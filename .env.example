# ==============================================================================
# MENTORGRAPH ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to a new file named '.env' in the workspace root and fill
# in your specific credentials.

# 1. Google Cloud Authentication & Project Coordinates
# Path to your GCP Service Account credentials JSON key file.
# Leave blank if you are using 'gcloud auth application-default login'
GOOGLE_APPLICATION_CREDENTIALS=c:\path\to\your\credentials.json

# Your target GCP Project ID
GOOGLE_CLOUD_PROJECT=your-gcp-enterprise-project

# Target Google Cloud deployment region
GCP_LOCATION=us-central1

# 2. BigQuery Data Store Configuration
# Name of the BigQuery dataset where employees & courses tables reside
BQ_DATASET_NAME=hr_dataset

# 3. Sandbox Development / Fallback Switches
# Set to 'False' to strictly run production GCP BigQuery/LMS queries.
# Set to 'True' to fallback to local mock data if GCP credentials are unconfigured.
USE_MOCK_BQ=True
USE_MOCK_LMS=True

# 4. Live LLM Generation Testing
# (Optional) Set your Gemini API Key if you want run_local.py or deploy_gemini.py 
# to trigger actual, live Gemini 2.5 models rather than simulated responses.
GEMINI_API_KEY=your_gemini_api_key_here
